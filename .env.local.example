# 「雪と猫」環境変数のサンプル。
# このファイルを .env.local にコピーして YOUTUBE_API_KEY を入れてください。
# (チャンネルID・再生リストIDは公開情報なので初期値を入れてあります)

# Google Cloud Console で取得した YouTube Data API v3 のキー(必須・秘密)
YOUTUBE_API_KEY=

# チャンネル「雪と猫」のID(NEW行=最新アップロードの取得に使用)
YOUTUBE_CHANNEL_ID=UCvFprY_t9tiRBCdJxYafPkA

# 再生リストID(各行のデータソース)
PLAYLIST_CAT_DAILY=PL7ubwQRwLE0kQqnsBc-b_RTjCkkJ8EW72   # 猫の日常
PLAYLIST_CAT_DIY=PL7ubwQRwLE0mtZGJU90dIjAo-LnN1am4C      # 猫DIY
PLAYLIST_EXPERIMENT=PL7ubwQRwLE0kaBx5-X0u2IEn7GUCJ8925   # 実験ショート(食・モノ)
PLAYLIST_RELAX=PL7ubwQRwLE0k4MFpYAzeP-smbzkf6-Dh4        # ずっとみてられる
